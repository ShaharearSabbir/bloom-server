model Tutor {
    userId       String         @id @unique
    user         User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    categoryId   String
    category     Category       @relation(fields: [categoryId], references: [categoryId], onDelete: Cascade, onUpdate: Cascade)
    bio          String
    hourlyRate   Float
    profession   String
    avgRating    Float          @default(0)
    reviewCount  Int            @default(0)
    availability Availability[]
    reviews      Review[]
    bookings     Booking[]


    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([categoryId], name: "idx_Tutor_categoryId")
    @@index([hourlyRate], name: "idx_Tutor_hourlyRate")
    @@index([reviewCount], name: "idx_Tutor_reviewCount")
    @@index([createdAt], name: "idx_Tutor_createdAt")

    @@map("tutors")
}
