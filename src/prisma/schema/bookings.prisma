model Booking {
id String @id @default(uuid())
tutorId String
studentId String
categoryId String
bookingDate DateTime
startTime String
endTime String
totalFees Float
status BookingStatus @default(PENDING)
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt


tutor Tutor @relation(fields: [tutorId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
student User @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
category Category @relation(fields: [categoryId], references: [categoryId], onDelete: Cascade, onUpdate: Cascade)

 @@index([tutorId], name: "idx_bookings_tutorId")
 @@index([studentId], name: "idx_bookings_studentId")
 @@index([categoryId], name: "idx_bookings_categoryId")

 @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRM
  CANCELED
  COMPLETED
}